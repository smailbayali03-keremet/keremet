generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Request {
  id            Int      @id @default(autoincrement())
  token         String   @unique
  whatsappPhone String
  name          String
  cabinet       String
  requestType   String
  topic         String?
  size          String?
  info          String?
  style         String?
  urgency       String
  notes         String?
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
